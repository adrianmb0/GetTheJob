#!/bin/bash
# GetTheJob launcher — starts the dashboard server and opens the browser

# Ensure PATH includes common install locations
export PATH="/usr/local/bin:/opt/homebrew/bin:$HOME/.local/bin:$PATH"
[ -f "$HOME/.zprofile" ] && source "$HOME/.zprofile" 2>/dev/null
[ -f "$HOME/.bash_profile" ] && source "$HOME/.bash_profile" 2>/dev/null
[ -s "$HOME/.nvm/nvm.sh" ] && source "$HOME/.nvm/nvm.sh" 2>/dev/null

# Resolve project directory (the .app lives inside the project)
APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$APP_DIR" || exit 1

# Check Node.js (it bundles npm). Required once per machine/account — open the
# download page and tell the user to install it, then relaunch.
if ! command -v node &>/dev/null || ! command -v npm &>/dev/null; then
  open "https://nodejs.org/en/download" 2>/dev/null
  osascript -e 'display alert "GetTheJob needs Node.js" message "GetTheJob runs on Node.js (which includes npm). I opened the download page — install the LTS version, then click GetTheJob in your Dock again." as critical' 2>/dev/null
  exit 1
fi

# First run: dependencies not installed yet (a fresh clone has no node_modules).
# Run `npm install` visibly in Terminal so the user sees progress, then ask them
# to relaunch — instead of failing silently when the server can't find a package.
if [ ! -d "$APP_DIR/node_modules" ]; then
  /usr/bin/osascript \
    -e 'tell application "Terminal" to activate' \
    -e "tell application \"Terminal\" to do script \"cd '$APP_DIR' && echo Installing GetTheJob dependencies, please wait... && npm install && echo && echo Setup complete. Click GetTheJob in your Dock again to start.\"" 2>/dev/null
  exit 0
fi

# Detect an already-running instance. The server owns port 3737, so if it
# answers /api/ping the app is already open — just focus the browser instead of
# starting a second server (which would re-run the morning batch).
if curl -fsS -m 1 "http://localhost:3737/api/ping" >/dev/null 2>&1; then
  open "http://localhost:3737"
  exit 0
fi

# No healthy instance — clear any stale process holding the port, then start fresh.
lsof -ti:3737 | xargs kill 2>/dev/null || true
sleep 0.5

# Start the server (morning batch auto-launches inside server.mjs, respecting the 24h cooldown)
AUTOSTART_BATCH=1 node server.mjs &
SERVER_PID=$!
sleep 1

# Open the dashboard
open "http://localhost:3737"

# Auto-minimize the Terminal window
sleep 0.5
osascript -e 'tell application "Terminal" to set miniaturized of front window to true' 2>/dev/null

# Keep the app alive until the server exits
wait $SERVER_PID
